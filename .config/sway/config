# Sway config (migrated from i3)
# See https://swaywm.org/docs/ and `man 5 sway` for reference

# Font for window titles
font pango:Cascadia Code 10

# Modifier key (Alt)
set $mod Mod1

# Direction keys (vim-style)
set $up k
set $down j
set $left h
set $right l

# ─── Input ────────────────────────────────────────────────────────────────────

input * {
    xkb_layout us,latam
    xkb_options grp:win_space_toggle
}

# Mouse speed — replace "Logitech USB Receiver" with your actual device name
# Run `swaymsg -t get_inputs` to find the exact identifier
input "YOUR_LOGITECH_DEVICE_ID" {
    pointer_accel -0.8
}

seat seat0 xcursor_theme Bibata-Modern-Ice 28

# ─── Output / Wallpaper ───────────────────────────────────────────────────────

# Wallpaper (waypaper — GUI picker like nitrogen, uses swaybg backend)
exec waypaper --restore

# ─── Autostart ────────────────────────────────────────────────────────────────

# Export Wayland env vars so xdg-desktop-portal (file dialogs, etc.) works
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP=sway

exec --no-startup-id dex-autostart --autostart --environment sway
exec --no-startup-id nm-applet --indicator
exec --no-startup-id dunst
exec_always killall waybar; waybar

# Screen lock with swayidle + swaylock (replaces xss-lock + i3lock)
exec swayidle -w \
    timeout 300 'swaylock -c 000000' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    timeout 1800 'systemctl suspend' \
    before-sleep 'swaylock -c 000000'

# ─── Volume (PulseAudio / pactl) ──────────────────────────────────────────────

set $refresh_status killall -SIGUSR1 i3status

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_status
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_status
bindsym XF86AudioMicMute     exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_status

# ─── Dictation ────────────────────────────────────────────────────────────────

bindsym Mod1+space exec --no-startup-id dictate

# ─── Core Behavior ────────────────────────────────────────────────────────────

floating_modifier $mod normal
tiling_drag modifier
tiling_drag_threshold 0

# ─── Keybindings ──────────────────────────────────────────────────────────────

# Terminal
bindsym $mod+Return exec ghostty

# Kill focused window
bindsym $mod+Shift+q kill

# App launcher
bindsym $mod+d      exec "rofi -modi drun,run -show drun"
bindsym $mod+Tab    exec --no-startup-id rofi -show window

# Focus (vim keys)
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right

# Focus (arrow keys)
bindsym $mod+Left   focus left
bindsym $mod+Down   focus down
bindsym $mod+Up     focus up
bindsym $mod+Right  focus right

# Move window (vim keys)
bindsym $mod+Shift+$left  move left
bindsym $mod+Shift+$down  move down
bindsym $mod+Shift+$up    move up
bindsym $mod+Shift+$right move right

# Move window (arrow keys)
bindsym $mod+Shift+Left   move left
bindsym $mod+Shift+Down   move down
bindsym $mod+Shift+Up     move up
bindsym $mod+Shift+Right  move right

# Layout
bindsym $mod+slash  layout toggle split
bindsym $mod+comma  layout toggle tabbed stacked

# Split
bindsym $mod+bar    split h
bindsym $mod+underscore split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Floating
bindsym $mod+Shift+f floating toggle

# Focus parent
bindsym $mod+a focus parent

# Scratchpad
bindsym $mod+Shift+grave move scratchpad
bindsym $mod+grave       scratchpad show

# Resize shortcuts (AeroSpace-style)
bindsym $mod+equal  resize grow width 50px, resize grow height 50px
bindsym $mod+minus  resize shrink width 50px, resize shrink height 50px

# Screen lock (replaces i3lock)
bindsym $mod+Shift+Escape exec swaylock -c 000000

# Screenshots (grim + slurp — native Wayland)
bindsym Print       exec grim - | wl-copy
bindsym Shift+Print exec grim -g "$(slurp)" - | wl-copy

# Reload / restart / exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes, exit' 'swaymsg exit'

# ─── Resize Mode ──────────────────────────────────────────────────────────────

mode "resize" {
    bindsym $left       resize shrink width 10px
    bindsym $down       resize grow height 10px
    bindsym $up         resize shrink height 10px
    bindsym $right      resize grow width 10px

    bindsym Left        resize shrink width 10px
    bindsym Down        resize grow height 10px
    bindsym Up          resize shrink height 10px
    bindsym Right       resize grow width 10px

    bindsym Return      mode "default"
    bindsym Escape      mode "default"
    bindsym $mod+r      mode "default"
}

bindsym $mod+r mode "resize"

# ─── Service Mode ─────────────────────────────────────────────────────────────

mode "service" {
    bindsym Escape      mode "default"
    bindsym f           floating toggle, mode "default"
    bindsym BackSpace   [con_id="__focused__"] kill, mode "default"

    bindsym Down        exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
    bindsym Up          exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
    bindsym Shift+Down  exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ 0%

    bindsym $mod+Shift+semicolon mode "default"
}

bindsym $mod+Shift+semicolon mode "service"

# ─── Workspaces ───────────────────────────────────────────────────────────────

set $ws1  "1"
set $ws2  "2"
set $ws3  "3"
set $ws4  "4"
set $ws5  "5"
set $ws6  "6"
set $ws7  "7"
set $ws8  "8"
set $ws9  "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ─── Window Assignments ───────────────────────────────────────────────────────
# Note: Wayland-native apps use app_id, XWayland apps still use class.
# Run `swaymsg -t get_tree` to find the correct app_id or class for each app.

# Workspace 1: IDE
assign [class="Cursor"]    1
assign [class="Code"]      1
assign [class="VSCodium"]  1
assign [class="Windsurf"]  1
assign [app_id="cursor"]   1
assign [app_id="code"]     1
assign [app_id="windsurf"] 1

# Workspace 2: Browser / Terminal
assign [app_id="ghostty"]        2
assign [class="Ghostty"]         2
assign [app_id="kitty"]          2
assign [class="kitty"]           2
assign [app_id="org.mozilla.firefox"] 2
assign [class="Firefox"]         2
assign [app_id="google-chrome"]  2
assign [class="Google-chrome"]   2
assign [class="Chromium"]        2

# Workspace 3: LLMs
assign [class="LM Studio"]  3
assign [title="Claude"]     3

# Workspace 4: Dev apps
assign [class="Docker Desktop"] 4
assign [class="Postman"]        4

# Workspace 5: Slack / Linear
assign [class="Linear"] 5
assign [class="Slack"]  5
assign [app_id="slack"] 5

# Workspace 6: Mail
assign [class="Raindrop"]    6
assign [class="Spark"]       6
assign [class="Thunderbird"] 6
assign [app_id="net.thunderbird.Thunderbird"] 6

# ─── Floating Windows ─────────────────────────────────────────────────────────

for_window [app_id="thunar"]   floating enable
for_window [class="Thunar"]    floating enable
for_window [app_id="org.gnome.Nautilus"] floating enable
for_window [class="Nautilus"]  floating enable
for_window [class="Evince"]    floating enable
for_window [class="Atril"]     floating enable
for_window [class="Emulator"]  floating enable
for_window [class="qemu-system-x86_64"] floating enable
for_window [class="Emulator"]  border normal

# Scratchpad apps
for_window [app_id="org.gnome.Calculator"] floating enable, resize set 300 400, move scratchpad, scratchpad show
for_window [class="gnome-calculator"]  floating enable, resize set 300 400, move scratchpad, scratchpad show

# ─── Colors ───────────────────────────────────────────────────────────────────

include ~/.config/sway/themes/gruvbox-dark-soft

# class                 border           background         text                  indicator          child_border
client.focused          $focused-color   $inactive-bg-color $text-color           $indicator-color   $focused-color
client.unfocused        $unfocused-color   $inactive-bg-color $inactive-text-color $inactive-bg-color $unfocused-color
client.focused_inactive $unfocused-color   $inactive-bg-color $inactive-text-color $inactive-bg-color $unfocused-color
client.urgent           $urgent-bg-color $urgent-bg-color   $text-color           $urgent-bg-color   $urgent-bg-color

# ─── Gaps & Borders ───────────────────────────────────────────────────────────

gaps inner 10
gaps outer 10
smart_gaps off

default_border pixel 3
default_floating_border pixel 3


# ─── SwayFX ───────────────────────────────────────────────────────────────────

corner_radius 10
blur enable
blur_xray disable
blur_passes 2
blur_radius 5
shadows enable
